@startuml
skinparam classAttributeIconSize 0

' --- Иерархия строителей ---
abstract class Строитель {
    + сила: int
    + имя: String
    + строить(дом: Дом)
}

abstract class Животное extends Строитель {
    + найти_друга()
}

class Чебурашка extends Животное {
    + сила = 50
    + собрано_кирпичей: int = 0
    + добавить_кирпич(кирпич: Кирпич)
}

class Гена extends Животное {
    + сила = 70
    + инструмент: String = "Гармошка"
    + играть_на_гармошке()
    + передать_кирпич(кирпич: Кирпич, чебурашка: Чебурашка)
}

' --- Иерархия материалов ---
abstract class Материал {
    + вес: int
    + id: int
    + использовать()
}

class Кирпич extends Материал {
    + вес = 5
    + материал: String = "Глина"
}

' --- Строительный объект ---
class Дом {
    + количество_кирпичей: int = 0
    + статус: СтатусДома = "ПРОЕКТ"
    + добавить_кирпич(кирпич: Кирпич)
    + построить()
    + зарегистрировать_друзей()
}

enum СтатусДома {
    ПРОЕКТ
    СТРОИТЕЛЬСТВО
    ПОСТРОЕН
}

' СВЯЗИ
Чебурашка --> Кирпич : использует >
Гена --> Кирпич : передает >
Чебурашка --> Дом : строит >
Гена --> Дом : строит >
Дом --> СтатусДома : имеет >

note right of Чебурашка::добавить_кирпич
  **Builder Pattern**
  Каждый добавленный кирпич
  увеличивает счетчик.
  При достижении 100 кирпичей
  дом считается построенным.
end note

note bottom of Гена
  Гена — единственный,
  кто умеет играть на гармошке
  и создавать праздничную атмосферу.
end note

@enduml
